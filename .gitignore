# ============================================================
# .gitignore — Files to exclude from Git / GitHub
# ============================================================

# Dependencies — auto-generated by npm install, never commit
node_modules/

# Production build output — generated by npm run build
build/

# Environment variables — contains secrets, never commit
.env
.env.local
.env.production

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/

.vercel
